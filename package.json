{
  "name": "claude-code-nest",
  "displayName": "Claude Code Nest",
  "description": "A virtual organization layer over Claude Code chat sessions: folders, tags, links, and read-only smart groups for a single project.",
  "version": "0.0.1",
  "publisher": "jakemismas",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakemismas/claude-code-nest.git"
  },
  "homepage": "https://github.com/jakemismas/claude-code-nest#readme",
  "bugs": {
    "url": "https://github.com/jakemismas/claude-code-nest/issues"
  },
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "chat history",
    "sessions",
    "organize",
    "folders",
    "tags"
  ],
  "galleryBanner": {
    "color": "#1E1B4B",
    "theme": "dark"
