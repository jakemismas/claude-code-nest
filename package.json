{
  "name": "claude-code-nest",
  "displayName": "Claude Code Nest",
  "description": "A virtual organization layer over Claude Code chat sessions: folders, tags, links, and read-only smart groups for a single project.",
  "version": "0.0.1",
  "publisher": "jakemismas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakemismas/claude-code-nest.git"
  },
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:claudeNest.flat",
    "onView:claudeNest.folders",
    "onView:claudeNest.tags",
    "onView:claudeNest.smartGroups",
    "onCommand:claudeNest.openSettings",
    "onCommand:claudeNest.exportLibrary",
    "onCommand:claudeNest.importLibrary"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeNest",
          "title": "Claude Code Nest",
          "icon": "media/nest.svg"
        }
      ]
    },
    "views": {
      "claudeNest": [
        {
          "id": "claudeNest.flat",
          "name": "Chats",
          "contextualTitle": "Claude Code Nest"
        },
        {
          "id": "claudeNest.folders",
          "name": "Folders",
          "contextualTitle": "Claude Code Nest"
        },
        {
          "id": "claudeNest.tags",
          "name": "Tags",
          "contextualTitle": "Claude Code Nest"
        },
        {
          "id": "claudeNest.smartGroups",
          "name": "Smart Groups",
          "contextualTitle": "Claude Code Nest"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeNest.flat",
        "contents": "No Claude Code chats found for this workspace yet.\nOpen a folder that has Claude Code sessions, then refresh.\n[Refresh](command:claudeNest.refresh)"
      },
      {
        "view": "claudeNest.folders",
        "contents": "No Claude Code chats found for this workspace yet.\nOpen a folder that has Claude Code sessions, then create a folder.\n[New Folder](command:claudeNest.createFolder)"
      },
      {
        "view": "claudeNest.tags",
        "contents": "No Claude Code chats found for this workspace yet.\nOpen a folder that has Claude Code sessions, then create a tag.\n[New Tag](command:claudeNest.createTag)"
      },
      {
        "view": "claudeNest.smartGroups",
        "contents": "No Claude Code chats found for this workspace yet.\nSmart Groups are read-only buckets computed from your transcripts (pull request, ticket prefix, git branch, fork lineage).\n[Refresh](command:claudeNest.refreshSmartGroups)"
      }
    ],
    "commands": [
      {
        "command": "claudeNest.openChat",
        "title": "Open Chat",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.refresh",
        "title": "Refresh",
        "category": "Claude Code Nest",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeNest.refreshFolders",
        "title": "Refresh Folders",
        "category": "Claude Code Nest",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeNest.createFolder",
        "title": "New Folder",
        "category": "Claude Code Nest",
        "icon": "$(new-folder)"
      },
      {
        "command": "claudeNest.renameFolder",
        "title": "Rename Folder",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.deleteFolder",
        "title": "Delete Folder",
        "category": "Claude Code Nest",
        "icon": "$(trash)"
      },
      {
        "command": "claudeNest.assignChatToFolder",
        "title": "Move Chat to Folder",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.refreshTags",
        "title": "Refresh Tags",
        "category": "Claude Code Nest",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeNest.createTag",
        "title": "New Tag",
        "category": "Claude Code Nest",
        "icon": "$(add)"
      },
      {
        "command": "claudeNest.deleteTag",
        "title": "Delete Tag",
        "category": "Claude Code Nest",
        "icon": "$(trash)"
      },
      {
        "command": "claudeNest.addTagToChat",
        "title": "Add Tag to Chat",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.removeTagFromChat",
        "title": "Remove Tag from Chat",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.tagChats",
        "title": "Tag Chats...",
        "category": "Claude Code Nest",
        "icon": "$(tag)"
      },
      {
        "command": "claudeNest.linkToChat",
        "title": "Link to Chat...",
        "category": "Claude Code Nest",
        "icon": "$(git-branch)"
      },
      {
        "command": "claudeNest.unlinkChat",
        "title": "Unlink",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.refreshSmartGroups",
        "title": "Refresh Smart Groups",
        "category": "Claude Code Nest",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeNest.promoteSmartGroupToFolder",
        "title": "Promote to Folder",
        "category": "Claude Code Nest",
        "icon": "$(new-folder)"
      },
      {
        "command": "claudeNest.promoteSmartGroupToTag",
        "title": "Promote to Tag",
        "category": "Claude Code Nest",
        "icon": "$(tag)"
      },
      {
        "command": "claudeNest.openSettings",
        "title": "Claude Code Nest Settings",
        "category": "Claude Code Nest",
        "icon": "$(gear)"
      },
      {
        "command": "claudeNest.exportLibrary",
        "title": "Export Library to JSON...",
        "category": "Claude Code Nest",
        "icon": "$(export)"
      },
      {
        "command": "claudeNest.importLibrary",
        "title": "Import Library from JSON...",
        "category": "Claude Code Nest",
        "icon": "$(import)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeNest.refresh",
          "when": "view == claudeNest.flat",
          "group": "navigation"
        },
        {
          "command": "claudeNest.createFolder",
          "when": "view == claudeNest.folders",
          "group": "navigation@1"
        },
        {
          "command": "claudeNest.refreshFolders",
          "when": "view == claudeNest.folders",
          "group": "navigation@2"
        },
        {
          "command": "claudeNest.createTag",
          "when": "view == claudeNest.tags",
          "group": "navigation@1"
        },
        {
          "command": "claudeNest.refreshTags",
          "when": "view == claudeNest.tags",
          "group": "navigation@2"
        },
        {
          "command": "claudeNest.refreshSmartGroups",
          "when": "view == claudeNest.smartGroups",
          "group": "navigation@1"
        },
        {
          "command": "claudeNest.openSettings",
          "when": "view == claudeNest.flat",
          "group": "navigation@9"
        },
        {
          "command": "claudeNest.openSettings",
          "when": "view == claudeNest.folders",
          "group": "navigation@9"
        },
        {
          "command": "claudeNest.openSettings",
          "when": "view == claudeNest.tags",
          "group": "navigation@9"
        },
        {
          "command": "claudeNest.openSettings",
          "when": "view == claudeNest.smartGroups",
          "group": "navigation@9"
        },
        {
          "command": "claudeNest.exportLibrary",
          "when": "view == claudeNest.flat",
          "group": "9_backup@1"
        },
        {
          "command": "claudeNest.importLibrary",
          "when": "view == claudeNest.flat",
          "group": "9_backup@2"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeNest.createFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.folder",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.renameFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.folder",
          "group": "1_modify@2"
        },
        {
          "command": "claudeNest.deleteFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.folder",
          "group": "1_modify@3"
        },
        {
          "command": "claudeNest.assignChatToFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.chat",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.assignChatToFolder",
          "when": "view == claudeNest.flat && viewItem == claudeNest.chat",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.deleteTag",
          "when": "view == claudeNest.tags && viewItem == claudeNest.tag",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.removeTagFromChat",
          "when": "view == claudeNest.tags && viewItem == claudeNest.tagChat",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.addTagToChat",
          "when": "view == claudeNest.folders && viewItem == claudeNest.chat",
          "group": "1_modify@2"
        },
        {
          "command": "claudeNest.addTagToChat",
          "when": "view == claudeNest.flat && viewItem == claudeNest.chat",
          "group": "1_modify@2"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "view == claudeNest.flat && viewItem == claudeNest.chat",
          "group": "1_modify@3"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "view == claudeNest.flat && viewItem == claudeNest.chat",
          "group": "inline"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "view == claudeNest.folders && viewItem == claudeNest.chat",
          "group": "1_modify@3"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "view == claudeNest.folders && viewItem == claudeNest.chat",
          "group": "inline"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "view == claudeNest.tags && viewItem == claudeNest.tagChat",
          "group": "1_modify@2"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "view == claudeNest.tags && viewItem == claudeNest.tagChat",
          "group": "inline"
        },
        {
          "command": "claudeNest.linkToChat",
          "when": "view == claudeNest.folders && viewItem == claudeNest.chat",
          "group": "2_link@1"
        },
        {
          "command": "claudeNest.linkToChat",
          "when": "view == claudeNest.flat && viewItem == claudeNest.chat",
          "group": "2_link@1"
        },
        {
          "command": "claudeNest.unlinkChat",
          "when": "view == claudeNest.folders && viewItem == claudeNest.linkedChild",
          "group": "2_link@1"
        },
        {
          "command": "claudeNest.unlinkChat",
          "when": "view == claudeNest.folders && viewItem == claudeNest.linkedChildBroken",
          "group": "2_link@1"
        },
        {
          "command": "claudeNest.promoteSmartGroupToFolder",
          "when": "view == claudeNest.smartGroups && viewItem == claudeNest.smartGroupBucket",
          "group": "1_promote@1"
        },
        {
          "command": "claudeNest.promoteSmartGroupToTag",
          "when": "view == claudeNest.smartGroups && viewItem == claudeNest.smartGroupBucket",
          "group": "1_promote@2"
        },
        {
          "command": "claudeNest.promoteSmartGroupToFolder",
          "when": "view == claudeNest.smartGroups && viewItem == claudeNest.smartGroupBucket",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "claudeNest.openChat",
          "when": "false"
        },
        {
          "command": "claudeNest.renameFolder",
          "when": "false"
        },
        {
          "command": "claudeNest.deleteFolder",
          "when": "false"
        },
        {
          "command": "claudeNest.assignChatToFolder",
          "when": "false"
        },
        {
          "command": "claudeNest.deleteTag",
          "when": "false"
        },
        {
          "command": "claudeNest.addTagToChat",
          "when": "false"
        },
        {
          "command": "claudeNest.removeTagFromChat",
          "when": "false"
        },
        {
          "command": "claudeNest.tagChats",
          "when": "false"
        },
        {
          "command": "claudeNest.unlinkChat",
          "when": "false"
        },
        {
          "command": "claudeNest.promoteSmartGroupToFolder",
          "when": "false"
        },
        {
          "command": "claudeNest.promoteSmartGroupToTag",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run compile",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run lint && npm run compile",
    "test": "mocha",
    "test:integration": "node ./out/test/integration/runTest.js",
    "package": "vsce package --no-dependencies -o nest-build-check.vsix"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "@types/vscode": "1.66.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^8.57.0",
    "mocha": "^10.4.0",
    "typescript": "^5.4.5"
  }
}
