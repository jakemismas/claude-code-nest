{
  "name": "claude-code-nest",
  "displayName": "Claude Code Nest",
  "description": "A virtual organization layer over Claude Code chat sessions: folders, tags, links, and read-only smart groups for a single project.",
  "version": "0.0.1",
  "publisher": "jakemismas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakemismas/claude-code-nest.git"
  },
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:claudeNest.flat",
    "onView:claudeNest.folders"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeNest",
          "title": "Claude Code Nest",
          "icon": "media/nest.svg"
        }
      ]
    },
    "views": {
      "claudeNest": [
        {
          "id": "claudeNest.flat",
          "name": "Chats",
          "contextualTitle": "Claude Code Nest"
        },
        {
          "id": "claudeNest.folders",
          "name": "Folders",
          "contextualTitle": "Claude Code Nest"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeNest.flat",
        "contents": "No Claude Code chats found for this workspace yet.\nOpen a folder that has Claude Code sessions, then refresh.\n[Refresh](command:claudeNest.refresh)"
      },
      {
        "view": "claudeNest.folders",
        "contents": "No Claude Code chats found for this workspace yet.\nOpen a folder that has Claude Code sessions, then create a folder.\n[New Folder](command:claudeNest.createFolder)"
      }
    ],
    "commands": [
      {
        "command": "claudeNest.openChat",
        "title": "Open Chat",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.refresh",
        "title": "Refresh",
        "category": "Claude Code Nest",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeNest.refreshFolders",
        "title": "Refresh Folders",
        "category": "Claude Code Nest",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeNest.createFolder",
        "title": "New Folder",
        "category": "Claude Code Nest",
        "icon": "$(new-folder)"
      },
      {
        "command": "claudeNest.renameFolder",
        "title": "Rename Folder",
        "category": "Claude Code Nest"
      },
      {
        "command": "claudeNest.deleteFolder",
        "title": "Delete Folder",
        "category": "Claude Code Nest",
        "icon": "$(trash)"
      },
      {
        "command": "claudeNest.assignChatToFolder",
        "title": "Move Chat to Folder",
        "category": "Claude Code Nest"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeNest.refresh",
          "when": "view == claudeNest.flat",
          "group": "navigation"
        },
        {
          "command": "claudeNest.createFolder",
          "when": "view == claudeNest.folders",
          "group": "navigation@1"
        },
        {
          "command": "claudeNest.refreshFolders",
          "when": "view == claudeNest.folders",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeNest.createFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.folder",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.renameFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.folder",
          "group": "1_modify@2"
        },
        {
          "command": "claudeNest.deleteFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.folder",
          "group": "1_modify@3"
        },
        {
          "command": "claudeNest.assignChatToFolder",
          "when": "view == claudeNest.folders && viewItem == claudeNest.chat",
          "group": "1_modify@1"
        },
        {
          "command": "claudeNest.assignChatToFolder",
          "when": "view == claudeNest.flat && viewItem == claudeNest.chat",
          "group": "1_modify@1"
        }
      ],
      "commandPalette": [
        {
          "command": "claudeNest.openChat",
          "when": "false"
        },
        {
          "command": "claudeNest.renameFolder",
          "when": "false"
        },
        {
          "command": "claudeNest.deleteFolder",
          "when": "false"
        },
        {
          "command": "claudeNest.assignChatToFolder",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run compile",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run lint && npm run compile",
    "test": "mocha",
    "test:integration": "node ./out/test/integration/runTest.js",
    "package": "vsce package --no-dependencies -o nest-build-check.vsix"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "@types/vscode": "1.66.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^8.57.0",
    "mocha": "^10.4.0",
    "typescript": "^5.4.5"
  }
}
