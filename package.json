    "configuration": {
      "title": "Claude Code Nest",
      "properties": {
        "claudeNest.archiveKeepWindowDays": {
          "type": "number",
          "default": 30,
          "enum": [
            7,
            30,
            90,
            0
          ],
          "enumDescriptions": [
            "Keep archived chat copies for 7 days, then prune unstarred ones.",
            "Keep archived chat copies for 30 days, then prune unstarred ones.",
            "Keep archived chat copies for 90 days, then prune unstarred ones.",
            "Never prune: keep every archived chat copy forever."
          ],
          "markdownDescription": "How long Nest keeps its own copy of an archived chat's body in extension storage before pruning it. Starred archived chats are always kept, even past this window. `0` means never prune. The copy lets an archived chat survive Claude Code's own cleanup of `~/.claude/projects`; it is local and is never synced."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "claudeNest.gettingStarted",
        "title": "Get Started with Claude Code Nest",
        "description": "Organize your Claude Code chat sessions into folders, tags, links, and smart groups, all read-only over your transcripts.",
        "steps": [
          {
            "id": "claudeNest.walkthrough.openView",
            "title": "Open the Nest panel",
            "description": "Click the Claude Code Nest icon in the Activity Bar to open the Chats, Folders, Tags, and Smart Groups views for the current workspace.\n[Open Chats](command:claudeNest.refresh)",
            "media": {
              "markdown": "media/walkthrough/open-view.md"
            }
          },
          {
            "id": "claudeNest.walkthrough.organize",
            "title": "Organize with folders and tags",
            "description": "Create a folder or a tag, then drag a chat onto it. A chat has one folder home and any number of tags.\n[New Folder](command:claudeNest.createFolder)\n[New Tag](command:claudeNest.createTag)",
            "media": {
              "markdown": "media/walkthrough/organize.md"
            }
          },
          {
            "id": "claudeNest.walkthrough.smartGroups",
            "title": "Explore smart groups",
            "description": "Smart Groups are read-only buckets computed from your transcripts (pull request, ticket prefix, git branch, fork lineage). Promote a bucket to a real folder or tag when it is useful.\n[Refresh Smart Groups](command:claudeNest.refreshSmartGroups)",
            "media": {
              "markdown": "media/walkthrough/smart-groups.md"
            }
          },
          {
            "id": "claudeNest.walkthrough.backup",
            "title": "Back up your library",
            "description": "Your organization syncs best-effort across machines. The export JSON is the authoritative backup; export it to a synced or git-tracked location.\n[Export Library](command:claudeNest.exportLibrary)",
            "media": {
              "markdown": "media/walkthrough/backup.md"
            }
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "claudeNest.flat",
        "contents": "No Claude Code chats found for this workspace yet.\nOpen a folder that has Claude Code sessions, then refresh.\n[Refresh](command:claudeNest.refresh)"
